# Environment Variables Configuration

## Required Variables

# Database
MONGO_URI=mongodb://127.0.0.1:27017/web-dev-project

# Server
PORT=3000

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_ACCESS_SECRET=your_access_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Mocking Configuration
# NODE_ENV is used to determine default auto mock behavior (development/test = mock, production = real)
NODE_ENV=development

# LLM_MOCK_MODE options: auto, always, never
LLM_MOCK_MODE=auto

# LLM_MOCK_SCENARIO options: success, error, timeout
LLM_MOCK_SCENARIO=success

# LLM_MOCK_DELAY_MS simulates network delay for realistic testing
LLM_MOCK_DELAY_MS=1000