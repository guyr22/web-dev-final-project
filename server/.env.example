# Environment Variables Configuration
# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
# Local MongoDB (with auth): mongodb://<user>:<pass>@127.0.0.1:27017/<db>?authSource=admin
MONGO_URI=mongodb://127.0.0.1:27017/web-dev-project

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT Secrets (CHANGE THESE IN PRODUCTION!) ─────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production set to your domain: https://YOUR_DOMAIN
ALLOWED_ORIGINS=http://localhost:5173

# ── HTTPS (production only) ───────────────────────────────────────────────────
# Set HTTPS=true and provide paths to PEM files generated by certs/generate-certs.sh
HTTPS=false
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Set to true to mock AI responses during development/testing (no API calls)
AI_MOCK_MODE=true